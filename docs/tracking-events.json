        "service_name": "fractional-head-of-design | ux-audit | landing-page-design"
      },
      "implementation": "useAnalytics().trackServicePageVisit(serviceName)",
      "value": 25
    },
    {
      "name": "form_submit",
      "category": "Conversion",
      "description": "Fired when user submits contact form",
      "parameters": {
        "form_type": "contact | newsletter | other"
      },
      "implementation": "useAnalytics().trackFormSubmit(formType)",
      "value": 75
    },
    {
      "name": "scroll_depth",
      "category": "Engagement",
      "description": "Fired at scroll milestones: 25%, 50%, 75%, 100%",
      "parameters": {
        "depth": "25 | 50 | 75 | 100"
      },
      "implementation": "useAnalytics().trackScrollDepth(depth)",
      "value": null
    },
    {
      "name": "section_view",
      "category": "Engagement",
      "description": "Fired when specific section enters viewport",
      "parameters": {
        "section_name": "services | portfolio | experience | testimonials | about | contact"
      },
      "implementation": "useAnalytics().trackSectionView(sectionName)",
      "value": null
    }
