{
  "events": [
    {
      "name": "language_switch",
      "category": "User Interaction",
      "description": "Fired when user switches between Italian and English",
      "parameters": {
        "language": "it | en"
      },
      "implementation": "useAnalytics().trackLanguageSwitch(language)",
      "value": null
    },
    {
      "name": "calendly_click",
      "category": "Conversion",
      "description": "Fired when user clicks Calendly booking button",
      "parameters": {
        "location": "hero | services | contact | footer"
      },
      "implementation": "useAnalytics().trackCalendlyClick(location)",
      "value": 100
    },
    {
      "name": "email_click",
      "category": "Conversion",
      "description": "Fired when user clicks email contact button",
      "parameters": {
        "location": "hero | services | contact | footer"
      },
      "implementation": "useAnalytics().trackEmailClick(location)",
      "value": 50
    },
    {
      "name": "portfolio_view",
      "category": "Engagement",
      "description": "Fired when user views portfolio case study",
      "parameters": {
        "project_name": "C2 RTM-4 | Rekord AMRC | BSB | SIV | etc."
      },
      "implementation": "useAnalytics().trackPortfolioView(projectName)",
      "value": 10
    },
    {
      "name": "service_page_visit",
      "category": "Engagement",
      "description": "Fired when user visits service detail page",
