    {
      "goal_name": "Contact via Email",
      "event_name": "email_click",
      "value": 50,
      "description": "Secondary conversion - user initiates email contact"
    },
    {
      "goal_name": "Form Submission",
      "event_name": "form_submit",
      "value": 75,
      "description": "User submits contact form"
    },
    {
      "goal_name": "Service Page Engagement",
      "event_name": "service_page_visit",
      "value": 25,
      "description": "User shows interest by visiting service details"
    },
    {
      "goal_name": "Portfolio Engagement",
      "event_name": "portfolio_view",
      "value": 10,
      "description": "User explores work samples"
    }
  ]
